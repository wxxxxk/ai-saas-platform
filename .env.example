# ─── 프로필 ────────────────────────────────────────────────
# prod 프로필로 기동할 때 설정한다.
SPRING_PROFILES_ACTIVE=prod

# ─── PostgreSQL (docker-compose 기본값) ────────────────────
DB_URL=jdbc:postgresql://localhost:5432/aisaasdb
DB_USERNAME=aisaas
DB_PASSWORD=aisaas_dev_pw

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── JWT ──────────────────────────────────────────────────
# 운영용: openssl rand -base64 48 로 생성
JWT_SECRET=replace-with-secure-random-string-at-least-32-bytes!!
