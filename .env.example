# ============================================================
# AI SaaS Platform — 환경변수 예시
# 복사 후 실제 값으로 교체하세요: cp .env.example .env
# .env 는 git에 절대 커밋하지 마세요.
# ============================================================

# ─── PostgreSQL ──────────────────────────────────────────────
# docker-compose의 postgres 컨테이너 + backend가 함께 사용
DB_USERNAME=aisaas
DB_PASSWORD=change_me_strong_password

# ─── JWT ─────────────────────────────────────────────────────
# 32자 이상 랜덤 문자열. 생성: openssl rand -base64 48
JWT_SECRET=replace-with-secure-random-string-at-least-32-bytes

# ─── OpenAI ──────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ─── Supabase Storage ────────────────────────────────────────
# 1. https://supabase.com 프로젝트 생성
# 2. Storage → New bucket → Name: "images", Public: ✓
# 3. Settings → API 탭에서 값 확인
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_BUCKET=images

# ─── (참고) docker-compose 내부 고정값 ───────────────────────
# BACKEND_URL=http://backend:8080  ← docker-compose.yml에 직접 설정됨
# DB_URL=jdbc:postgresql://postgres:5432/aisaasdb  ← docker-compose.yml 고정
